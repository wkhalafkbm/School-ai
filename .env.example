# University branding — shown in the app header
UNIVERSITY_NAME="University AI Operating Center"

# AI backend mode: "scripted" | "live" | "hybrid"
# scripted  — all AI responses served from fixture files (safe for offline demos)
# live      — calls watsonx Orchestrate for all recommendation moments
# hybrid    — live for featured moments, scripted fallback for the rest
AI_MODE=scripted

# PostgreSQL connection (used by FastAPI and Alembic)
DATABASE_URL=postgresql://uniai:uniai@localhost:5432/uniaidb

# watsonx Orchestrate credentials (only required when AI_MODE=live or hybrid)
WXO_BASE_URL=https://your-instance.cloud.ibm.com
WXO_API_KEY=
WXO_ENVIRONMENT_ID=live

# Per-agent IDs — from the school-ai Orchestrate environment (issue #22)
AGENT_ID_ADMISSIONS=29abb85f-2275-4a56-b9cc-b0c023e1d0a0
